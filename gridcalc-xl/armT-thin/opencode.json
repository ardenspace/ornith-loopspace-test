{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "agent": {
    "implementer": {
      "mode": "subagent",
      "description": "Implementation dispatches: write or fix code and tests to satisfy a brief. Routes to the local ornith model.",
      "model": "ornith/ornith-1.0-35b-Q5_K_M"
    },
    "verifier": {
      "mode": "subagent",
      "description": "Verification dispatches: adversarially check work against the spec and acceptance criteria.",
      "model": "openai/gpt-5.5"
    }
  },
  "provider": {
    "ornith": {
      "name": "Ornith Local llama.cpp",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:18081/v1",
        "apiKey": "local",
        "timeout": 900000,
        "headerTimeout": 900000,
        "chunkTimeout": 300000
      },
      "models": {
        "ornith-1.0-35b-Q5_K_M": {
          "id": "ornith-1.0-35b-Q5_K_M.gguf",
          "name": "Ornith 1.0 35B Q5_K_M",
          "family": "qwen",
          "temperature": true,
          "reasoning": false,
          "tool_call": true,
          "cost": { "input": 0, "output": 0 },
          "limit": { "context": 131072, "output": 30000 },
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    }
  }
}
