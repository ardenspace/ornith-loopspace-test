from gridcalc import Workbook

print('=== R12: 256-cell chain test ===')
wb = Workbook()
sheet = wb.add_sheet('chain')

# Create a single chain: A1=1, B1=A1+1, C1=B1+1, ..., Z1=Y1+1, A2=Z1+1, B2=A2+1, ...
cells = []
for r in range(1, 11):
    for c in range(1, 27):
        col = chr(64 + c)
        cell = f'{col}{r}'
        cells.append(cell)
        if len(cells) == 256:
            break
    if len(cells) == 256:
        break

# Set first cell to 1
sheet.set(cells[0], 1)

# Set each subsequent cell to reference the previous + 1
for i in range(1, len(cells)):
    sheet.set(cells[i], f'={cells[i-1]} + 1')

# Evaluate last cell - should be 256
result = sheet.get(cells[-1])
print(f'Last cell ({cells[-1]}): {result}')
print(f'Expected: 256')
print(f'Pass: {result == 256}')

print()
print('=== R28: Parser depth test ===')
wb = Workbook()
sheet = wb.add_sheet('test')

# Create a formula with 500 nested unary minuses
formula = '=' + '-' * 500 + '1'
sheet.set('A1', formula)
result = sheet.get('A1')
print(f'A1 result: {result}')
print(f'Expected: 1 (500 minuses = even, so positive 1)')
print(f'Pass: {result == 1}')
"

