from gridcalc import Workbook

# Test R10: Incremental recomputation
wb = Workbook()
s = wb.add_sheet('S1')
s.set('A1', 1)
s.set('A2', '=A1+1')
s.get('A2')
print(f'After first get: eval_count = {s.eval_count}')
s.set('A1', 2)  # Relevant edit
s.get('A2')
print(f'After relevant edit: eval_count = {s.eval_count}')

