from gridcalc import Workbook

# Test R12: Size bounds - 256-cell chain within grid
wb = Workbook()
s = wb.add_sheet('S1')
# Use a 16x16 grid (A1:P16) = 256 cells
for r in range(1, 17):
    for c in range(1, 17):
        col = chr(ord('A') + c - 1)
        addr = f'{col}{r}'
        if r == 1 and c == 1:
            s.set(addr, 1)
        else:
            # Reference the previous cell
            if c == 1:
                prev_col = chr(ord('A') + 15)
                prev_addr = f'{prev_col}{r-1}'
            else:
                prev_col = chr(ord('A') + c - 2)
                prev_addr = f'{prev_col}{r}'
            s.set(addr, f'={prev_addr}+1')
result = s.get('P16')
print(f'256-cell chain result: {result}')

# Test R17: Copy rewrite with out-of-grid
wb2 = Workbook()
s2 = wb2.add_sheet('S1')
s2.set('Z1', 1)
s2.set('A1', '=Z1')
s2.copy('A1', 'B1')
print(f'Out-of-grid copy: {s2.get(\"B1\")}')

# Test R22-R23: Multi-sheet with qualifiers
wb3 = Workbook()
s1 = wb3.add_sheet('S1')
s2 = wb3.add_sheet('S2')
s1.set('A1', 42)
s2.set('A1', '=S1!A1')
print(f'Cross-sheet ref: {s2.get(\"A1\")}')

# Test R24-R25: Persistence with formulas
wb4 = Workbook()
s4 = wb4.add_sheet('S1')
s4.set('A1', 10)
s4.set('A2', '=A1*2')
j = wb4.to_json()
wb5 = Workbook.from_json(j)
s5 = wb5.sheet('S1')
print(f'Persisted formula: {s5.get(\"A2\")}')
