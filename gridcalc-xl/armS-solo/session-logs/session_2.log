from gridcalc.parser import parse
from gridcalc.evaluator import _ev, _Ctx, _ev_binop, _arith, _is_err
from gridcalc import Workbook

wb = Workbook()
s = wb.add_sheet('S1')
ast = parse('1/0+1')
print('AST:', ast)
print('AST.op:', ast.op)
print('AST.left:', ast.left)
print('AST.right:', ast.right)

# Evaluate left
left = _ev(ast.left, wb, 'S1', _Ctx(wb, 'S1', wb.clock))
print('Left:', left, type(left))

# Evaluate right
right = _ev(ast.right, wb, 'S1', _Ctx(wb, 'S1', wb.clock))
print('Right:', right, type(right))

# Check types
print('left is int:', isinstance(left, int))
print('right is int:', isinstance(right, int))

# Call _arith
result = _arith('/', left, right)
print('Result from _arith:', result)
"
