+def evaluate(formula_text: str, wb, host: str, ctx: _Ctx) -> object:
+    """Public evaluate function: parse and evaluate a formula text.
+
+    This is the entry point called by Sheet.get().
+    """
+    from .parser import parse as _parse
+
+    sheet = wb.sheets.get(host)
+    if sheet is not None:
+        sheet._eval_count += 1
+
+    ast = _parse(formula_text)
+    if ast is None:
+        result = _ERR_PARSE
+    else:
+        result = _ev(ast, wb, host, ctx)
+
+    if sheet is not None:
+        sheet._eval_cache[formula_text] = result  # Note: this is wrong, should use addr
+
+    return result

