    def test_256_cell_chain_no_raise():
        """256 formula cells in a chain should evaluate without raising."""
        s = Sheet()
        s.set("A1", "=1")
        prev = "A1"
        for i in range(2, 257):
            col_idx = (i - 1) % 26
            row_idx = (i - 1) // 26 + 1
            if row_idx > 99:
                row_idx = (row_idx - 1) % 99 + 1
            addr = f"{chr(ord('A') + col_idx)}{row_idx}"
            s.set(addr, f"={prev}+1")
            prev = addr
        val = s.get(prev)
