timestamp=2026-07-13T01:46:47.828Z level=INFO run=2b879f60 message=evaluated permission=bash pattern="python3 -c \"\nfrom gridcalc import Sheet\n\n# Criterion 1: set never changes eval_count\ns = Sheet()\ns.set('A1', 1)\nassert s.eval_count == 0, 'set literal should not change count'\ns.set('B1', '=A1+1')\nassert s.eval_count == 0, 'set formula should not change count'\ns.get('B1')\nassert s.eval_count == 1, 'get formula should increment count'\ns.set('A1', 10)\nassert s.eval_count == 1, 'set after eval should not change count'\nprint('Criterion 1: PASS')\n\n# Criterion 2: literal/empty reads add 0\ns = Sheet()\ns.set('A1', 42)\ns.get('A1')\nassert s.eval_count == 0, 'literal read should not increment count'\ns.get('Z99')  # empty\nassert s.eval_count == 0, 'empty read should not increment count'\nprint('Criterion 2: PASS')\n\n# Criterion 3: repeat read adds 0, errors cached\ns = Sheet()\ns.set('A1', '=1/0')\ns.get('A1')\nc1 = s.eval_count\ns.get('A1')\nassert s.eval_count == c1, 'repeat get should not re-evaluate'\nassert s.get('A1') == '#DIV!'\n\ns.set('A1', '=A2')\ns.set('A2', '=A1')\ns.get('A1')\nc2 = s.eval_count\ns.get('A1')\nassert s.eval_count == c2, 'cycle result should be cached'\nassert s.get('A1') == '#CYCLE!'\nprint('Criterion 3: PASS')\n\n# Criterion 4: after set, gets reflect current sheet\ns = Sheet()\ns.set('A1', 1)\ns.set('B1', '=A1+1')\ns.get('B1')\nassert s.get('B1') == 2\ns.set('A1', 10)\nassert s.get('B1') == 11, 'after set, get should reflect new value'\nprint('Criterion 4: PASS')\n\n# Criterion 5: counter-visible short-circuit for literal 1/0\ns = Sheet()\ns.set('A1', 1)\ns.set('Y1', '=A1*2')\ns.set('B1', '=1/0+Y1')\ns.get('B1')\nassert s.eval_count == 1, f'Y1 should not be evaluated, count={s.eval_count}'\nassert s.get('B1') == '#DIV!'\nprint('Criterion 5: PASS')\n\n# Criterion 6a: SUM short-circuit\ns = Sheet()\ns.set('A1', 1)\ns.set('A2', '=1/0')\ns.set('A3', 3)\ns.set('B1', '=SUM(A1:A3)')\ns.get('B1')\nassert s.eval_count == 2, f'SUM should evaluate B1+A2, count={s.eval_count}'\nassert s.get('B1') == '#DIV!'\nprint('Criterion 6a: PASS')\n\n# Criterion 6b: COUNT doesn't evaluate range members\ns = Sheet()\ns.set('A1', 1)\ns.set('A2', '=1/0')\ns.set('A3', '=2+2')\ns.set('B1', '=COUNT(A1:A3)')\ns.get('B1')\nassert s.eval_count == 1, f'COUNT should only evaluate B1, count={s.eval_count}'\nassert s.get('B1') == 3\nprint('Criterion 6b: PASS')\n\n# Criterion 6c: MIN short-circuit on literal string\ns = Sheet()\ns.set('A1', 5)\ns.set('A2', 'hello')\ns.set('A3', 3)\ns.set('B1', '=MIN(A1:A3)')\ns.get('B1')\nassert s.eval_count == 1, f'MIN should only evaluate B1, count={s.eval_count}'\nassert s.get('B1') == '#TYPE!'\nprint('Criterion 6c: PASS')\n\n# Criterion 6d: MAX short-circuit\ns = Sheet()\ns.set('A1', 5)\ns.set('A2', '=1/0')\ns.set('A3', 3)\ns.set('B1', '=MAX(A1:A3)')\ns.get('B1')\nassert s.eval_count == 2, f'MAX should evaluate B1+A2, count={s.eval_count}'\nassert s.get('B1') == '#DIV!'\nprint('Criterion 6d: PASS')\n\nprint()\nprint('All criteria verified independently.')\n\"" action.permission=* action.action=allow action.pattern=*
