formula = 'SUM(A1:B2)'

    def tokenize(formula):
        """Tokenize formula text into a list of (type, value) tuples.
    
        Args:
            formula: Formula text (without leading '=')
    
        Returns:
            List of (type, value) tuples
    
        Raises:
            ParseError: If tokenization fails
        """
        tokens = []
        i = 0
        while i < len(formula):
            c = formula[i]
    
            # Skip whitespace (spaces and tabs)
            if c in " \t":
                i += 1
                continue
    
            # Numbers
