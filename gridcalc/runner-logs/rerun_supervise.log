from gridcalc.evaluator import evaluate, _eval_node, _eval_reference
from gridcalc.parser import parse

# Create a simple sheet-like object
class FakeSheet:
    def __init__(self):
        self._store = {'A1': '=A2', 'A2': '=A1'}
    
    def get(self, addr):
        return self._store.get(addr)

sheet = FakeSheet()

# Parse and evaluate A1
