import sys
sys.setrecursionlimit(500)  # Set a lower limit to test

from gridcalc import Sheet

s = Sheet()
cells = []
for row in range(1, 100):
    cells.append(f'A{row}')
for row in range(1, 100):
    cells.append(f'B{row}')
for row in range(1, 59):
    cells.append(f'C{row}')

s.set(cells[0], 1)
for i in range(1, 256):
    s.set(cells[i], f'={cells[i-1]}+1')

# Try getting C2 with debug
import gridcalc.evaluator as ev
original_eval_ref = ev._eval_reference

def debug_eval_ref(addr, sheet, _evaluating):
    print(f'_eval_reference({addr}), _evaluating size before: {len(_evaluating)}')
    result = original_eval_ref(addr, sheet, _evaluating)
    print(f'_eval_reference({addr}) returned {result}, _evaluating size after: {len(_evaluating)}')
    return result

ev._eval_reference = debug_eval_ref

try:
    result = s.get('C2')
    print(f'Final result: {result}')
except RecursionError as e:
    print(f'RecursionError: {e}')
except Exception as e:
    print(f'Error: {type(e).__name__}: {e}')
