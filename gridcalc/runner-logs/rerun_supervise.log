from gridcalc import Sheet
from gridcalc.parser import parse
from gridcalc.evaluator import evaluate

s = Sheet()
cells = []
for row in range(1, 100):
    cells.append(f'A{row}')
for row in range(1, 100):
    cells.append(f'B{row}')
for row in range(1, 59):
    cells.append(f'C{row}')

s.set(cells[0], 1)
for i in range(1, 256):
    s.set(cells[i], f'={cells[i-1]}+1')

# Try evaluating C2 directly without the broad exception handler
