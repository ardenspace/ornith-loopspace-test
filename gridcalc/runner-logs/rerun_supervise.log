from gridcalc.sheet import Sheet
from gridcalc.parser import parse

# Test R12: 512-char formula
formula = '1+' * 250 + '1'  # 501 chars
print(f'Testing {len(formula)}-char formula...')
try:
    ast = parse(formula)
    print('  Parse OK')
except Exception as e:
    print(f'  Parse FAILED: {e}')

# Test R12: 32-deep parens
formula = '(' * 32 + '1' + ')' * 32
print(f'Testing 32-deep parens formula ({len(formula)} chars)...')
try:
    ast = parse(formula)
    print('  Parse OK')
except Exception as e:
    print(f'  Parse FAILED: {e}')

# Test R12: 256-cell chain (should not raise RecursionError)
s = Sheet()
s.set('A1', 1)
for i in range(2, 257):
    s.set(f'A{i}', f'=A{i-1}')
print('Testing 256-cell chain...')
try:
    result = s.get('A256')
    print(f'  Result: {result}')
except RecursionError:
    print('  RecursionError raised (BAD)')
except Exception as e:
    print(f'  Other error: {e}')
