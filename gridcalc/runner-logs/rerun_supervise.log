# Use A1, B1, C1, ... (26 columns) x multiple rows
chain = []
for col in range(26):
    for row in range(1, 10):  # 9 rows per column
        chain.append(f'{chr(65+col)}{row}')
        if len(chain) >= 256:
            break
    if len(chain) >= 256:
        break

chain = chain[:256]
print(f'Chain length: {len(chain)}')

# Set up the chain: each cell references the next
