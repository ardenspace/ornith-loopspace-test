timestamp=2026-07-13T00:26:31.091Z level=INFO run=6ffd9487 message=evaluated permission=bash pattern="python3 -c \"\nfrom gridcalc.sheet import Sheet\n\n# Self-reference\ns = Sheet()\ns.set('A1', '=A1')\nassert s.get('A1') == '#CYCLE!', f'Self-ref failed: {s.get(\\\"A1\\\")}'\nprint('✓ Self-reference: #CYCLE!')\n\n# Mutual cycle\ns = Sheet()\ns.set('A1', '=B1')\ns.set('B1', '=A1')\nassert s.get('A1') == '#CYCLE!', f'Mutual A1 failed: {s.get(\\\"A1\\\")}'\nassert s.get('B1') == '#CYCLE!', f'Mutual B1 failed: {s.get(\\\"B1\\\")}'\nprint('✓ Mutual cycle: both #CYCLE!')\n\n# Through SUM range\ns = Sheet()\ns.set('A1', '=A2')\ns.set('A2', '=A1')\ns.set('B1', '=SUM(A1:A2)')\nassert s.get('B1') == '#CYCLE!', f'SUM range failed: {s.get(\\\"B1\\\")}'\nprint('✓ SUM range cycle: #CYCLE!')\n\n# COUNT does not participate\ns = Sheet()\ns.set('A1', '=COUNT(A1:A1)')\nassert s.get('A1') == 1, f'COUNT self-ref failed: {s.get(\\\"A1\\\")}'\nprint('✓ COUNT self-ref: 1 (not cycle)')\n\n# Propagation\ns = Sheet()\ns.set('A1', '=A2')\ns.set('A2', '=A1')\ns.set('B1', '=A1')\nassert s.get('B1') == '#CYCLE!', f'Propagation failed: {s.get(\\\"B1\\\")}'\nprint('✓ Propagation: #CYCLE!')\n\n# Recovery\ns = Sheet()\ns.set('A1', '=A2')\ns.set('A2', '=A1')\nassert s.get('A1') == '#CYCLE!'\ns.set('A1', 5)\nassert s.get('A1') == 5, f'Recovery A1 failed: {s.get(\\\"A1\\\")}'\nassert s.get('A2') == 5, f'Recovery A2 failed: {s.get(\\\"A2\\\")}'\nprint('✓ Recovery: correct values after breaking cycle')\n\nprint()\nprint('All acceptance criteria verified!')\n\"" action.permission=* action.action=allow action.pattern=*
