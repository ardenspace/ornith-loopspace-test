# Parse C2
formula_c2 = s._store['C2'][1:]
ast_c2 = parse(formula_c2)
print(f'C2 AST: {ast_c2}')

# Evaluate C2 with fresh _evaluating
_evaluating = set()
try:
    result = evaluate(ast_c2, s, _evaluating)
    print(f'C2 result: {result}')
except Exception as e:
    print(f'C2 error: {type(e).__name__}: {e}')
    import traceback
    traceback.print_exc()
