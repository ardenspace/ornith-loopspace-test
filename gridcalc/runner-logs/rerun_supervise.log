from gridcalc import Sheet
import gridcalc.sheet as sheet_module

# Monkey-patch _evaluate_cell to see what error is caught
original_evaluate_cell = sheet_module.Sheet._evaluate_cell

def debug_evaluate_cell(self, addr):
    value = self._store.get(addr)
    
    if value is None:
        self._cache[addr] = None
        self._dirty.discard(addr)
        return None
    
    if isinstance(value, str) and value.startswith('='):
        from gridcalc.parser import parse as parser_parse
        from gridcalc.evaluator import evaluate as eval_formula
        
        formula = value[1:]
        try:
            ast = parser_parse(formula)
            self._eval_count += 1
            result = eval_formula(ast, self, self._evaluating)
            self._cache[addr] = result
            self._dirty.discard(addr)
            return result
        except Exception as e:
            print(f'ERROR in _evaluate_cell({addr}): {type(e).__name__}: {e}')
            import traceback
            traceback.print_exc()
            self._eval_count += 1
            result = '#PARSE!'
            self._cache[addr] = result
            self._dirty.discard(addr)
            return result
    
    self._cache[addr] = value
    self._dirty.discard(addr)
    return value

sheet_module.Sheet._evaluate_cell = debug_evaluate_cell

s = Sheet()
cells = []
for row in range(1, 100):
    cells.append(f'A{row}')
for row in range(1, 100):
    cells.append(f'B{row}')
for row in range(1, 59):
    cells.append(f'C{row}')

s.set(cells[0], 1)
for i in range(1, 256):
    s.set(cells[i], f'={cells[i-1]}+1')

print('Getting C2...')
result = s.get('C2')
print(f'C2 result: {result}')
