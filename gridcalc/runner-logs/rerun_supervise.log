import sys
from gridcalc import Sheet

def make_chain(size):
    cells = []
    # Use columns to get enough cells
    col_idx = 0
    row = 1
    while len(cells) < size:
        col = chr(ord('A') + col_idx)
        if row > 99:
            row = 1
            col_idx += 1
        cells.append(f'{col}{row}')
        row += 1
    return cells[:size]

# Test chains of increasing size
for size in [50, 100, 150, 198, 199, 200, 250]:
    cells = make_chain(size)
    s = Sheet()
    s.set(cells[0], 1)
    for i in range(1, size):
        s.set(cells[i], f'={cells[i-1]}+1')
    
    try:
        result = s.get(cells[-1])
        print(f'Size {size}: OK (result={result})')
    except RecursionError:
        print(f'Size {size}: RecursionError')
    except Exception as e:
        print(f'Size {size}: {type(e).__name__}: {e}')
"
