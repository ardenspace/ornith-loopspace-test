from gridcalc import Sheet

s = Sheet()
cells = []
for row in range(1, 100):
    cells.append(f'A{row}')
for row in range(1, 100):
    cells.append(f'B{row}')
for row in range(1, 59):
    cells.append(f'C{row}')

s.set(cells[0], 1)
for i in range(1, 256):
    s.set(cells[i], f'={cells[i-1]}+1')

# Get C199 (C2) with recursion limit tracking
import gridcalc.evaluator as ev
original_eval = ev.evaluate

def tracking_evaluate(ast, sheet, _evaluating=None):
    import traceback
    if _evaluating is not None and len(_evaluating) > 200:
        print(f'WARNING: _evaluating has {len(_evaluating)} items')
        traceback.print_stack(limit=10)
    return original_eval(ast, sheet, _evaluating)

ev.evaluate = tracking_evaluate

try:
    result = s.get('C2')
    print(f'Result: {result}')
except RecursionError as e:
    print(f'RecursionError caught: {e}')
except Exception as e:
    print(f'Other error: {type(e).__name__}: {e}')
