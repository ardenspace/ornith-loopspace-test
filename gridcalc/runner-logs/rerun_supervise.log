timestamp=2026-07-13T02:18:08.320Z level=INFO run=2b879f60 message=evaluated permission=bash pattern="cat > /tmp/verify_bounds.py << 'EOF'\nfrom gridcalc import Sheet\n\n# Test repeat read\nprint(\"Test: Repeat read (two consecutive get with no set)\")\ns = Sheet()\ns.set(\"A1\", 1)\ns.set(\"B1\", \"=A1+1\")\ns.get(\"B1\")\nfirst_count = s.eval_count\ns.get(\"B1\")\nassert s.eval_count == first_count, f\"Expected {first_count}, got {s.eval_count}\"\nprint(\"  PASS\")\n\n# Test irrelevant edit\nprint(\"Test: Irrelevant edit (Y outside X's closure)\")\ns = Sheet()\ns.set(\"A1\", 1)\ns.set(\"B1\", 2)\ns.set(\"C1\", \"=A1+B1\")\ns.get(\"C1\")\nfirst_count = s.eval_count\ns.set(\"A2\", 10)  # Outside C1's closure\ns.get(\"C1\")\nassert s.eval_count == first_count, f\"Expected {first_count}, got {s.eval_count}\"\nprint(\"  PASS\")\n\n# Test relevant edit\nprint(\"Test: Relevant edit (Y inside X's closure)\")\ns = Sheet()\ns.set(\"A1\", 1)\ns.set(\"B1\", \"=A1+1\")\ns.get(\"B1\")\nfirst_count = s.eval_count\ns.set(\"A1\", 10)  # Inside B1's closure\ns.get(\"B1\")\nassert s.eval_count > first_count, f\"Expected > {first_count}, got {s.eval_count}\"\nprint(f\"  PASS (added {s.eval_count - first_count})\")\n\n# Test relevant edit with identical content\nprint(\"Test: Relevant edit with identical content\")\ns = Sheet()\ns.set(\"A1\", 5)\ns.set(\"B1\", \"=A1+1\")\ns.get(\"B1\")\nfirst_count = s.eval_count\ns.set(\"A1\", 5)  # Same value\ns.get(\"B1\")\nassert s.eval_count > first_count, f\"Expected > {first_count}, got {s.eval_count}\"\nprint(f\"  PASS (added {s.eval_count - first_count})\")\n\n# Test no full-sheet recompute\nprint(\"Test: No full-sheet recompute (bound by closure size)\")\ns = Sheet()\ns.set(\"A1\", 1)\ns.set(\"A2\", 2)\ns.set(\"A3\", 3)\ns.set(\"B1\", \"=A1\")\ns.set(\"B2\", \"=A2\")\ns.set(\"B3\", \"=A3\")\ns.set(\"C1\", \"=B1+B2+B3\")\ns.get(\"C1\")\nfirst_count = s.eval_count\ns.set(\"A1\", 10)  # Inside closure\ns.get(\"C1\")\n# Closure formula cells: C1, B1, B2, B3 = 4\nmax_allowed = first_count + 4\nassert s.eval_count <= max_allowed, f\"Expected <= {max_allowed}, got {s.eval_count}\"\nprint(f\"  PASS (added {s.eval_count - first_count}, max allowed {4})\")\n\n# Test edit leaves X literal\nprint(\"Test: Edit leaves X literal (final get adds 0)\")\ns = Sheet()\ns.set(\"A1\", 1)\ns.set(\"B1\", \"=A1+1\")\ns.get(\"B1\")\nfirst_count = s.eval_count\ns.set(\"B1\", 100)  # Overwrite with literal\ns.get(\"B1\")\nassert s.eval_count == first_count, f\"Expected {first_count}, got {s.eval_count}\"\nprint(\"  PASS\")\n\nprint(\"\\nAll bounds tests passed!\")\nEOF" action.permission=* action.action=allow action.pattern=*
