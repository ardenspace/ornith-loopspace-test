from gridcalc.evaluator import _eval_node, _eval_reference, _is_valid_grid_address, ERROR_CYCLE, ERROR_REF, ERROR_TYPE, ERROR_PARSE, ERROR_DIV
from gridcalc.parser import parse

# Create a simple sheet-like object
class FakeSheet:
    def __init__(self):
        self._store = {'A1': '=A2', 'A2': '=A1'}
    
    def get(self, addr):
        return self._store.get(addr)

sheet = FakeSheet()

# Manually trace through _eval_reference for A2
_evaluating = set()
addr = 'A2'
print(f'=== Evaluating {addr} ===')
print(f'Valid address: {_is_valid_grid_address(addr)}')
print(f'In _evaluating: {addr in _evaluating}')

value = sheet.get(addr)
print(f'Value from sheet.get: {value!r}')

if value is None:
    print('Empty cell')
elif isinstance(value, str) and value in (ERROR_PARSE, ERROR_REF, ERROR_TYPE, ERROR_DIV):
    print(f'Error cell: {value}')
elif isinstance(value, str) and value.startswith('='):
    print(f'Formula cell: {value}')
    if addr in _evaluating:
        print(f'CYCLE DETECTED!')
    else:
        _evaluating.add(addr)
        print(f'Added {addr} to _evaluating: {_evaluating}')
        formula = value[1:]
        print(f'Parsing formula: {formula!r}')
        try:
            ast = parse(formula)
            print(f'AST: {ast}')
            # Now evaluate A1
            print(f'Evaluating A1...')
            result = _eval_node(ast, sheet, _evaluating)
            print(f'Result: {result}')
        except Exception as e:
            print(f'Exception: {type(e).__name__}: {e}')
            import traceback
            traceback.print_exc()
elif isinstance(value, str):
    print(f'String cell: {value}')
elif isinstance(value, int):
    print(f'Number cell: {value}')
