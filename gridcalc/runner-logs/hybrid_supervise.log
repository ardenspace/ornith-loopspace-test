timestamp=2026-07-14T02:11:06.998Z level=INFO run=18ee9f84 message=evaluated permission=bash pattern="python - <<'PY'\nfrom gridcalc import Sheet\ncases = [\n    ('=1+2*3', 7), ('=(1+2)*3', 9), ('=--1', 1), ('=2--3', 5), ('=007', 7),\n    ('=7/2', 3), ('=-7/2', -3), ('=7/-2', -3), ('=7/0', '#DIV!'),\n    ('=Z9+1', 1), ('=A01', '#REF!'), ('=A0', '#REF!'), ('=A100', '#REF!'), ('=1$2', '#PARSE!')\n]\nfor formula, expected in cases:\n    s=Sheet(); s.set('A1', formula); got=s.get('A1')\n    print(formula, got, expected, got == expected)\ns=Sheet(); s.set('A1','x'); s.set('B1','=A1'); print('string ref', s.get('B1'))\ns=Sheet(); s.set('A1','=1')\nfor i in range(2,257):\n    col=(i-1)%26; row=(i-1)//26+1; addr=f'{chr(65+col)}{row}'\n    pcol=(i-2)%26; prow=(i-2)//26+1; prev=f'{chr(65+pcol)}{prow}'\n    s.set(addr, f'={prev}+1')\nlast=f'{chr(65+(255%26))}{255//26+1}'\nprint('chain', last, s.get(last))\nPY" action.permission=* action.action=allow action.pattern=*
