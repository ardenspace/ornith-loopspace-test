timestamp=2026-07-14T03:06:32.836Z level=INFO run=18ee9f84 message=evaluated permission=bash pattern="python - <<'PY'\nfrom gridcalc import Sheet\nfrom gridcalc.parser import parse\ncases = []\n# compose examples\ns=Sheet(); s.set('A1',1); s.set('B1',2); s.set('A2',3); s.set('B2',4); s.set('C1','=SUM(A1:B2)+1'); cases.append(('sum compose', s.get('C1'), 11))\ns=Sheet(); s.set('A1',1); s.set('A2',5); s.set('B1','=-MAX(A1:A2)*2'); cases.append(('max unary', s.get('B1'), -10))\ns=Sheet(); s.set('A1',1); s.set('B2',2); s.set('C1','=SUM(A1 : B2)'); cases.append(('ws colon', s.get('C1'), 3))\nfor f in ['=AVG(A1:A2)', '=sum(A1:B2)', '=SUM(A1)', '=A1:B2', '=SUM((A1:B2))']:\n    s=Sheet(); s.set('C1', f); cases.append((f, s.get('C1'), '#PARSE!'))\nfor f in ['=SUM(B2:A1)', '=SUM(A0:B2)', '=SUM(A1:A100)']:\n    s=Sheet(); s.set('C1', f); cases.append((f, s.get('C1'), '#REF!'))\ns=Sheet(); s.set('A1','=1/0'); s.set('B1','text'); s.set('A2',5); s.set('C1','=SUM(A1:B2)'); cases.append(('first row-major', s.get('C1'), '#DIV!'))\ns=Sheet(); s.set('A1','=SUM(A2:B2)'); cases.append(('sum empty', s.get('A1'), 0))\ns=Sheet(); s.set('A1','=MIN(A2:B2)'); cases.append(('min empty', s.get('A1'), '#TYPE!'))\ns=Sheet(); s.set('A1','=MAX(A2:B2)'); cases.append(('max empty', s.get('A1'), '#TYPE!'))\ns=Sheet(); s.set('A1','x'); s.set('B1','=SUM(A1:A1)'); cases.append(('sum string', s.get('B1'), '#TYPE!'))\ns=Sheet(); s.set('A1','=COUNT(A1:A1)'); cases.append(('count self', s.get('A1'), 1))\ns=Sheet(); s.set('A1','=1/0'); s.set('B1','x'); s.set('C1','=COUNT(A1:B1)'); cases.append(('count no eval', s.get('C1'), 2))\nfor name, got, exp in cases:\n    print(name, got, exp, 'OK' if got == exp else 'BAD')\nPY" action.permission=* action.action=allow action.pattern=*
