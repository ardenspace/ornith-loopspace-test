timestamp=2026-07-14T03:39:30.675Z level=INFO run=18ee9f84 message=evaluated permission=bash pattern="python -c \"\nfrom gridcalc import Sheet\n\n# Test compose: =SUM(A1:B2)+1\ns = Sheet()\ns.set('A1', 1); s.set('B1', 2); s.set('A2', 3); s.set('B2', 4)\ns.set('C1', '=SUM(A1:B2)+1')\nprint('SUM compose:', s.get('C1'))  # expect 11\n\n# Test compose: =-MAX(A1:A2)*2\ns2 = Sheet()\ns2.set('A1', 5); s2.set('A2', 10)\ns2.set('B1', '=-MAX(A1:A2)*2')\nprint('MAX compose:', s2.get('B1'))  # expect -20\n\n# Test whitespace around :\ns3 = Sheet()\ns3.set('A1', 1); s3.set('B1', 2)\ns3.set('C1', '=SUM(A1 : B1)')\nprint('Whitespace:', s3.get('C1'))  # expect 3\n\n# Test #PARSE! cases\nfrom gridcalc.parser import parse\nprint('AVG:', parse('AVG(A1:A2)'))  # expect #PARSE!\nprint('sum:', parse('sum(A1:B2)'))  # expect #PARSE!\nprint('SUM(A1):', parse('SUM(A1)'))  # expect #PARSE!\nprint('A1:B2:', parse('A1:B2'))  # expect #PARSE!\nprint('SUM((A1:B2)):', parse('SUM((A1:B2))'))  # expect #PARSE!\n\n# Test #REF! cases\ns4 = Sheet()\ns4.set('A1', '=SUM(B2:A1)')\nprint('Mis-ordered:', s4.get('A1'))  # expect #REF!\ns4.set('B1', '=SUM(A0:B2)')\nprint('A0:', s4.get('B1'))  # expect #REF!\ns4.set('C1', '=SUM(A1:A100)')\nprint('A100:', s4.get('C1'))  # expect #REF!\n\n# Test row-major order\ns5 = Sheet()\ns5.set('B1', 'hello')  # #TYPE!\ns5.set('A2', '=1/0')  # #DIV!\ns5.set('C1', '=SUM(A1:B2)')\nprint('Row-major (B1 string, A2 div):', s5.get('C1'))  # expect #TYPE!\n\n# Test COUNT\ns6 = Sheet()\ns6.set('A1', '=COUNT(A1:A1)')\nprint('COUNT self-ref:', s6.get('A1'))  # expect 1\n\"" action.permission=* action.action=allow action.pattern=*
